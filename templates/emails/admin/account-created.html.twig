{#
  Template d'email de création de compte administrateur
  
  ⚠️ ATTENTION : Cet email contient des informations sensibles (mot de passe en clair).
  L'utilisateur doit changer son mot de passe et supprimer définitivement cet email.
  
  Variables requises:
    - user: Objet utilisateur avec les propriétés firstname, username, email
    - username: Nom d'utilisateur
    - mail: Adresse email
    - password: Mot de passe en clair
    - roles: Rôles formatés pour affichage
    - loginUrl: URL de connexion
    - changePasswordUrl: URL pour changer le mot de passe
    - createdBy: Origine de la création ('command' ou 'dashboard')
    - createdAt: Date de création
#}
{% extends 'layouts/email.html.twig' %}

{% set subject = 'Votre compte administrateur ' ~ app_name %}
{% set preheader = 'Vos identifiants de connexion pour ' ~ app_name ~ ' - Action requise' %}

{% block content %}
  {# Alerte de sécurité CRITIQUE en haut #}
  {% include 'emails/components/_alert.html.twig' with {
    type: 'danger',
    title: '⚠️ EMAIL CONFIDENTIEL - ACTION REQUISE',
    content: 'Cet email contient votre <strong>mot de passe en clair</strong>. Pour des raisons de sécurité, vous devez :<br><br>
    <strong>1.</strong> Vous connecter immédiatement<br>
    <strong>2.</strong> Changer votre mot de passe<br>
    <strong>3.</strong> <span style="color: #dc3545; font-weight: bold;">SUPPRIMER DÉFINITIVEMENT cet email</span> (pas dans la corbeille !)'
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Titre principal #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h1',
    content: 'Bienvenue dans l\'équipe ' ~ app_name ~ ' !',
    color: '#212529',
    margin: '0 0 20px 0'
  } %}

  {# Texte d'introduction #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Bonjour <strong>' ~ (user.firstname|default(user.username|default('cher administrateur'))) ~ '</strong>,',
    color: '#495057'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Un compte administrateur a été créé pour vous sur <strong>' ~ app_name ~ '</strong>' ~ (createdBy == 'command' ? ' via la ligne de commande' : ' depuis le tableau de bord') ~ '. Vous trouverez ci-dessous vos identifiants de connexion.',
    color: '#495057'
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Récapitulatif des identifiants #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h3',
    content: '🔐 Vos identifiants de connexion',
    color: '#212529',
    custom_style: 'margin-bottom: 15px;'
  } %}

  {% include 'emails/components/_card.html.twig' with {
    content: '
      <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="font-size: 14px;">
        <tr>
          <td style="padding: 12px 0; color: #6c757d; width: 160px; vertical-align: top;"><strong>Nom d\'utilisateur :</strong></td>
          <td style="padding: 12px 0; color: #212529; font-family: monospace; font-size: 15px; background: #f8f9fa; padding-left: 10px; border-radius: 4px;">' ~ username ~ '</td>
        </tr>
        <tr>
          <td style="padding: 12px 0; color: #6c757d; vertical-align: top;"><strong>Adresse email :</strong></td>
          <td style="padding: 12px 0; color: #212529;">' ~ mail ~ '</td>
        </tr>
        <tr>
          <td style="padding: 12px 0; color: #6c757d; vertical-align: top;"><strong>Mot de passe :</strong></td>
          <td style="padding: 12px 0; color: #dc3545; font-family: monospace; font-size: 15px; font-weight: bold; background: #fff3cd; padding-left: 10px; border-radius: 4px;">' ~ password ~ '</td>
        </tr>
        <tr>
          <td style="padding: 12px 0; color: #6c757d; vertical-align: top;"><strong>Rôle :</strong></td>
          <td style="padding: 12px 0; color: #0d6efd; font-weight: 600;">' ~ roles ~ '</td>
        </tr>
        <tr>
          <td style="padding: 12px 0; color: #6c757d; vertical-align: top;"><strong>Date de création :</strong></td>
          <td style="padding: 12px 0; color: #212529;">' ~ createdAt|date('d/m/Y à H:i') ~ '</td>
        </tr>
      </table>
    '
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Boutons d'action #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h3',
    content: '🚀 Prochaines étapes',
    color: '#212529'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Connectez vous dès maintenant pour accéder à votre espace d\'administration :',
    color: '#495057',
    custom_style: 'margin-bottom: 5px;'
  } %}

  {% include 'emails/components/_button.html.twig' with {
    url: loginUrl,
    label: 'Se connecter',
    background: '#0d6efd',
    custom_style: 'margin-bottom: 10px;'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Ou rendez vous sur ce lien pour modifier votre mot de passe directement:',
    color: '#495057',
    margin: '25px 0 10px 0',
    custom_style: 'margin-bottom: 5px;'
  } %}

  {% include 'emails/components/_button.html.twig' with {
    url: changePasswordUrl,
    label: 'Modifier mon mot de passe',
    background: '#198754',
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Rappel de sécurité final #}
  {% include 'emails/components/_alert.html.twig' with {
    type: 'warning',
    title: '🛡️ Rappel de sécurité',
    content: '<ul style="margin: 10px 0; padding-left: 20px;">
      <li style="margin-bottom: 8px;">Ne partagez <strong>jamais</strong> vos identifiants avec quiconque</li>
      <li style="margin-bottom: 8px;">Changez votre mot de passe dès votre première connexion</li>
      <li style="margin-bottom: 8px;">Utilisez un mot de passe fort (min. 12 caractères, majuscules, chiffres, symboles)</li>
      <li style="margin-bottom: 8px;"><strong style="color: #dc3545;">Supprimez définitivement cet email après avoir noté vos identifiants</strong></li>
    </ul>',
    custom_style: 'margin-bottom: 10px;'
  } %}

  {% include 'emails/components/_box.html.twig' with {
    background: '#f8d7da',
    padding: '15px 20px',
    content: '<p style="margin: 0; color: #721c24; font-size: 13px; text-align: center;">
      <strong>⚠️ IMPORTANT :</strong> Ne placez pas cet email dans la corbeille.<br>
      <strong>Supprimez-le définitivement</strong> pour éviter tout risque de compromission.
    </p>',
    custom_style: 'margin-bottom: 10px;'
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Message de fin #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Si vous n\'êtes pas à l\'origine de cette demande ou si vous pensez avoir reçu cet email par erreur, veuillez contacter immédiatement l\'équipe technique.',
    color: '#6c757d',
    size: '13px'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Bienvenue dans l\'équipe !<br><strong>L\'équipe ' ~ app_name ~ '</strong>',
    color: '#495057'
  } %}
{% endblock %}
