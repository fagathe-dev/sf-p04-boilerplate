{#
  Template d'email de bienvenue
  
  Variables requises:
    - user: Objet utilisateur avec les propriétés firstname, email
    - activation_url: URL d'activation du compte (optionnel)
#}
{% extends 'layouts/email.html.twig' %}

{% set subject = 'Bienvenue sur ' ~ app_name %}
{% set preheader = 'Votre compte a été créé avec succès !' %}

{% block content %}
  {# Titre principal #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h1',
    content: 'Bienvenue ' ~ user.firstname ~ ' !',
    color: '#212529',
    margin: '0 0 20px 0'
  } %}

  {# Texte d'introduction #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Nous sommes ravis de vous accueillir sur <strong>' ~ app_name ~ '</strong>. Votre compte a été créé avec succès.',
    color: '#495057'
  } %}

  {# Alerte info #}
  {% include 'emails/components/_alert.html.twig' with {
    type: 'info',
    title: 'Informations de connexion',
    content: 'Votre adresse email : <strong>' ~ user.email ~ '</strong>'
  } %}

  {# Bouton d'activation (si URL fournie) #}
  {% if activation_url is defined and activation_url %}
    {% include 'emails/components/_text.html.twig' with {
      level: 'p',
      content: 'Pour activer votre compte, veuillez cliquer sur le bouton ci-dessous :',
      color: '#495057'
    } %}

    {% include 'emails/components/_button.html.twig' with {
      url: activation_url,
      label: 'Activer mon compte'
    } %}

    {% include 'emails/components/_text.html.twig' with {
      level: 'small',
      content: 'Ce lien expire dans 24 heures.',
      color: '#6c757d'
    } %}
  {% endif %}

  {% include 'emails/components/_divider.html.twig' %}

  {# Ce que vous pouvez faire #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h3',
    content: 'Ce que vous pouvez faire maintenant :',
    color: '#212529'
  } %}

  {% include 'emails/components/_list.html.twig' with {
    type: 'unordered',
    items: [
      'Compléter votre profil',
      'Découvrir nos fonctionnalités',
      'Explorer le contenu disponible'
    ]
  } %}

  {# Message de fin #}
  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Si vous avez des questions, n\'hésitez pas à nous contacter.',
    color: '#495057'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'À très bientôt,<br><strong>L\'équipe ' ~ app_name ~ '</strong>',
    color: '#495057'
  } %}
{% endblock %}
