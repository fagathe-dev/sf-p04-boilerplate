{% extends 'layouts/email.html.twig' %}

{% set subject = 'Validation de votre nouvelle adresse e-mail' %}
{% set preheader = 'Cliquez pour valider le changement de votre adresse e-mail sur ' ~ app_name %}

{% block content %}
  {% include 'emails/components/_text.html.twig' with {
    level: 'h1',
    content: 'Changement d\'e-mail',
    color: '#212529',
    custom_style: 'margin-bottom:20px'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Bonjour <strong>' ~ (user.firstname|default(user.username|default('cher utilisateur'))) ~ '</strong>,',
    color: '#495057'
  } %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'p',
    content: 'Vous avez demandé à modifier l\'adresse e-mail de votre compte pour utiliser <strong>' ~ new_email ~ '</strong>. Veuillez confirmer cette modification en cliquant sur le bouton ci-dessous :',
    color: '#495057'
  } %}

  {% include 'emails/components/_button.html.twig' with {
    url: confirmationUrl,
    label: 'Confirmer mon nouvel e-mail',
    custom_style: 'margin: 20px auto; text-align: center;'
  } %}

  {% include 'emails/components/_alert.html.twig' with {
    type: 'warning',
    title: 'Lien à durée limitée',
    content: 'Ce lien expire dans <strong>' ~ (expires_in|default('24 heures')) ~ '</strong>. L\'ancienne adresse restera active tant que vous n\'aurez pas cliqué sur ce lien.',
    custom_style: 'margin: 10px auto;'
  } %}

  {% include 'emails/components/_divider.html.twig' %}

  {% include 'emails/components/_text.html.twig' with {
    level: 'small',
    content: 'Si vous n\'êtes pas à l\'origine de cette demande, vous pouvez ignorer cet e-mail en toute sécurité. Votre adresse e-mail actuelle ne sera pas modifiée.',
    color: '#6c757d',
    custom_style: 'margin: 10px 0;'
  } %}
{% endblock %}