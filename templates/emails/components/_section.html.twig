{# Props: bg_color, padding, content, align, custom_style #}
{% set bg_color = bg_color|default('transparent') %}
{% set padding = padding|default('20px 0') %}
{% set content = content|default('') %}
{% set align = align|default('left') %}
{% set custom_style = custom_style|default('') %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: 'Roboto', sans-serif; margin: 0; {{ custom_style }}">
  <tr>
    <td align="{{ align }}" style="font-family: 'Roboto', sans-serif; background-color: {{ bg_color }}; padding: {{ padding }}; text-align: {{ align }};">
      {{ content|raw }}
    </td>
  </tr>
</table>
