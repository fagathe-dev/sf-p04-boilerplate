{# Props: type (success|danger|info), content, custom_style #}
{% set type = type|default('info') %}
{% set content = content|default('') %}
{% set custom_style = custom_style|default('') %}

{% set colors = {
  success: { bg: '#d8f3e2', border: '#45cb85', text: '#0f5132' },
  danger: { bg: '#fde8e4', border: '#f06548', text: '#842029' },
  info: { bg: '#e0ddf6', border: '#4b38b3', text: '#2c2270' }
} %}
{% set c = colors[type]|default(colors.info) %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: 'Roboto', sans-serif; margin: 0; {{ custom_style }}">
  <tr>
    <td style="font-family: 'Roboto', sans-serif; background-color: {{ c.bg }}; border-left: 4px solid {{ c.border }}; color: {{ c.text }}; padding: 12px 16px; font-size: 14px; border-radius: 4px;">
      {{ content|raw }}
    </td>
  </tr>
</table>
