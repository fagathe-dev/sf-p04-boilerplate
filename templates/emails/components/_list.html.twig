{# Props: items (array), bullet_color, custom_style #}
{% set items = items|default([]) %}
{% set bullet_color = bullet_color|default('#4b38b3') %}
{% set custom_style = custom_style|default('') %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: 'Roboto', sans-serif; margin: 0; {{ custom_style }}">
  {% for item in items %}
  <tr>
    <td width="20" style="font-family: 'Roboto', sans-serif; vertical-align: top; padding: 4px 0; color: {{ bullet_color }}; font-size: 14px;" valign="top">&#8226;</td>
    <td style="font-family: 'Roboto', sans-serif; vertical-align: top; padding: 4px 0; color: #878a99; font-size: 14px;" valign="top">{{ item|raw }}</td>
  </tr>
  {% endfor %}
</table>
