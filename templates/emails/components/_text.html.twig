{# Props: level (h1-h6, p), size, color, content, align, custom_style #}
{% set level = level|default('p') %}
{% set content = content|default('') %}
{% set align = align|default('left') %}
{% set custom_style = custom_style|default(level == 'small' ? 'display: block;' : '') %}

{% set default_sizes = {
  h1: '32px', h2: '28px', h3: '24px', h4: '20px', h5: '16px', h6: '14px', p: '14px'
} %}
{% set size = size|default(default_sizes[level]|default('14px')) %}

{% if level starts with 'h' %}
  {% set color = color|default('#495057') %}
  {% set font_weight = '500' %}
{% else %}
  {% set color = color|default('#878a99') %}
  {% set font_weight = 'normal' %}
{% endif %}

<{{ level }} style="font-family: 'Roboto', sans-serif; font-size: {{ size }}; color: {{ color }}; font-weight: {{ font_weight }}; margin: 0; line-height: 1.5; text-align: {{ align }}; {{ custom_style }}">{{ content|raw }}</{{ level }}>
