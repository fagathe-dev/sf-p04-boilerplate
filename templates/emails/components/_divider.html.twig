{# Props: color, height, custom_style #}
{% set color = color|default('#e9ebec') %}
{% set height = height|default('1px') %}
{% set custom_style = custom_style|default('') %}

<table width="100%" cellpadding="0" cellspacing="0" style="font-family: 'Roboto', sans-serif; margin: 0; {{ custom_style }}">
  <tr>
    <td style="font-family: 'Roboto', sans-serif; padding: 12px 0;">
      <div style="height: {{ height }}; background-color: {{ color }}; line-height: {{ height }}; font-size: 0;">&nbsp;</div>
    </td>
  </tr>
</table>
