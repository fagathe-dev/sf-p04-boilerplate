# editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[{compose.yaml,compose.*.yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Configuration spécifique pour les fichiers Twig
[*.html.twig]
indent_style = space
indent_size = 2
# Configuration spécifique pour les fichiers HTML
[*.html]
indent_style = space
indent_size = 2

# Configuration spécifique pour les fichiers TypeScript
[*.{ts,tsx}]
indent_style = space
indent_size = 2

# Configuration spécifique pour les fichiers JavaScript
[*.{js,jsx}]
indent_style = space
indent_size = 2

# Configuration spécifique pour les fichiers CSS
[*.{css,scss}]
indent_style = space
indent_size = 2

# Configuration spécifique pour les fichiers YAML
[*.{yaml}]
indent_style = space
indent_size = 2